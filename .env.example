# GEMINI_API_KEY: Required for Gemini AI API calls in the web app (App.tsx).
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GITHUB_TOKEN: Required for running test.ts and server.ts locally.
# Uses the GitHub Copilot API (gpt-4.1-2025-04-14) to extract candidate info
# and demonstrate prompt injection resistance.
# Set to your GitHub personal access token or use the token from `gh auth token`.
GITHUB_TOKEN="MY_GITHUB_TOKEN"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
